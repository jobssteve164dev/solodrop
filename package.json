{
  "name": "solodrop",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.18",
  "publisher": "SZLK",
  "license": "MIT",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jobssteve164dev/solodrop.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "agent",
    "artifact",
    "share",
    "preview",
    "cloudflare",
    "markdown",
    "pdf"
  ],
  "activationEvents": [
    "onView:solodrop.sidebar",
    "onCommand:solodrop.shareCurrentFile",
    "onCommand:solodrop.chooseAndShare"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "solodrop.shareCurrentFile",
        "title": "%command.shareCurrentFile%",
        "category": "SoloDrop"
      },
      {
        "command": "solodrop.chooseAndShare",
        "title": "%command.chooseAndShare%",
        "category": "SoloDrop"
      },
      {
        "command": "solodrop.openSidebar",
        "title": "%command.openSidebar%",
        "category": "SoloDrop"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "solodrop.shareCurrentFile",
          "group": "navigation@9",
          "when": "resourceScheme == file"
        }
      ],
      "editor/title/context": [
        {
          "command": "solodrop.shareCurrentFile",
          "group": "navigation@9",
          "when": "resourceScheme == file"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "solodrop-sidebar-container",
          "title": "SoloDrop",
          "icon": "resources/activitybar.svg"
        }
      ]
    },
    "views": {
      "solodrop-sidebar-container": [
        {
          "type": "webview",
          "id": "solodrop.sidebar",
          "name": "%view.sidebar%"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "solodrop.deploymentMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "temporary",
            "authenticated"
          ],
          "enumDescriptions": [
            "%configuration.deploymentMode.auto%",
            "%configuration.deploymentMode.temporary%",
            "%configuration.deploymentMode.authenticated%"
          ],
          "description": "%configuration.deploymentMode.description%"
        },
        "solodrop.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-cn"
          ],
          "enumDescriptions": [
            "%configuration.language.auto%",
            "%configuration.language.en%",
            "%configuration.language.zh%"
          ],
          "description": "%configuration.language.description%"
        },
        "solodrop.confirmBeforeUpload": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.confirmBeforeUpload.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test test/*.test.js",
    "worker:check": "wrangler deploy --dry-run --config worker/wrangler.jsonc",
    "check": "npm run compile && npm test",
    "check:all": "npm run check && npm run worker:check",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.112.0"
  }
}
