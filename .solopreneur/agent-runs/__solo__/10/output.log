worker/src/web.mjs:23:  return `<input id="file" type="file" hidden><label id="drop" class="drop" for="file"><div><span class="upload-icon"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5M5 14v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><strong>拖入文件，立即生成分享页</strong><span>或点击选择文件 · 最大 10 MB</span></div></label><p id="picked" class="picked">支持 Markdown、代码、文本、图片、CSV、HTML、PDF、Word 和 PowerPoint</p><div class="share-options"><label class="check"><input id="allow-download" type="checkbox" checked><span><strong>允许下载原文件</strong><small>关闭后，页面只保留在线预览</small></span></label><label class="field"><span>文字水印（可选）</span><input id="watermark" maxlength="60" placeholder="例如：仅供客户审阅"></label><label class="field"><span>链接有效期</span><select id="expiry"><option value="day">1 天</option><option value="week" selected>7 天</option><option value="month">30 天</option>${user?'<option value="never">长期保留</option>':''}</select></label></div><label class="check"><input id="terms" type="checkbox"><span>我确认文件将通过公开链接访问，并同意 SoloDrop 在所选有效期内保存文件内容，直到到期或我主动删除。</span></label><button id="share" class="full" disabled>创建分享链接</button><p id="status" class="status" role="status" aria-live="polite"></p><div id="result" class="result" hidden><div class="result-title">${checkIcon}<span>链接已经可以分享</span></div><p><a id="short" class="result-link" target="_blank" rel="noreferrer"></a></p><div class="result-actions"><button id="copy" type="button">复制链接</button><button id="delete-share" type="button" class="secondary">删除分享</button></div>${user?'':'<div class="signup-nudge"><strong>需要长期保留？</strong><p>免费注册后可创建长期链接，并在不同设备查看分享记录。</p><a class="button" href="/register?from=share-success">免费创建账号</a></div>'}</div><style>.share-options{margin:16px 0;padding:14px;border:1px solid var(--line);border-radius:14px;background:var(--soft)}.share-options .check{margin:0 0 12px}.share-options small{display:block;margin-top:3px;color:var(--muted)}.share-options .field{margin:11px 0 0;font-size:13px;color:#454556}.share-options input[type=text],.share-options input:not([type]),.share-options select{width:100%;height:44px;border:1px solid #cfcfdd;border-radius:10px;padding:0 12px;background:#fff;font:inherit}.share-options select{cursor:pointer}</style>`;
worker/src/web.mjs:26:  const share = `<input id="file" type="file" hidden><label id="drop" class="drop" for="file"><div><span class="upload-icon"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5M5 14v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><strong>拖入文件，立即生成分享页</strong><span>或点击选择文件 · 最大 1 MB</span></div></label><p id="picked" class="picked">支持 Markdown、代码、文本、图片、CSV、HTML 和小型 PDF</p><label class="check"><input id="terms" type="checkbox"><span>我同意 <a href="https://www.cloudflare.com/terms/" target="_blank" rel="noreferrer">Cloudflare 服务条款</a>与<a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">隐私政策</a>，并理解分享链接公开、未认领资源约 60 分钟后自动删除。</span></label><button id="share" class="full" disabled>创建临时分享链接</button><p id="status" class="status" role="status" aria-live="polite"></p><div id="result" class="result" hidden><div class="result-title">${checkIcon}<span>链接已经可以分享</span></div><p><a id="short" class="result-link" target="_blank" rel="noreferrer"></a></p><div class="result-actions"><button id="copy" type="button">复制链接</button><a id="claim" class="button secondary" target="_blank" rel="noreferrer">认领到 Cloudflare</a></div>${user ? '' : '<div class="signup-nudge"><strong>下次更方便一点</strong><p>免费注册后，可以在不同设备查看后续分享记录。当前链接无需注册，已经可以使用。</p><a class="button" href="/register?from=share-success">免费创建账号</a></div>'}</div>`;
worker/src/web.mjs:27:  const body = `<main id="main"><div class="page"><section class="hero"><div><p class="eyebrow">无需安装 · 无需登录 · 可控网页分享</p><h1>把文件变成<br>任何人都能打开的网页。</h1><p class="hero-copy">让对方直接在浏览器里阅读，不必下载文件或安装对应软件；你可以决定是否提供下载、添加审阅水印，并控制链接保留时间。</p><div class="proof"><span>${checkIcon}文件加密存储</span><span>${checkIcon}到期自动删除</span><span>${checkIcon}下载与水印由你控制</span></div></div><div class="share-card">${managedShareForm(user)}</div></section><section class="trust-section" aria-labelledby="trust-title"><div class="section-head"><h2 id="trust-title">发网页，而不只是发文件</h2><p>接收者打开就能看，分享者保留对展示方式、下载入口和有效期的控制。</p></div><div class="trust-grid"><article class="trust-card"><h3>减少打开阻力</h3><p>方案、报告和演示稿无需先下载，也不要求对方安装 Word、PowerPoint 或其他应用。</p></article><article class="trust-card"><h3>适合审阅与交付</h3><p>关闭下载入口并添加文字水印，让页面更适合客户审阅、内部评审和阶段性交付。水印用于归属提示，不等同于 DRM。</p></article><article class="trust-card"><h3>生命周期清楚</h3><p>文件按所选有效期安全保存；到期后链接停止访问并自动清理，登录用户也可以创建长期分享。</p></article></div></section><section class="plugin-band"><div><h2>经常在 VS Code 里分享？</h2><p>安装 SoloDrop 插件，直接分享当前文件、拖入文件或从 Explorer 右键完成。</p></div><a class="button" href="https://marketplace.visualstudio.com/items?itemName=SZLK.solodrop">安装 VS Code 插件</a></section></div></main>`;
worker/src/web.mjs:28:  return shell('快速把文件分享成网页', body, `<script src="/pow.js"></script><script>window.SoloDrop.initShare(${MAX_FILE_BYTES});document.getElementById('copy').addEventListener('click',function(){navigator.clipboard.writeText(document.getElementById('short').href).then(()=>{this.textContent='已复制'})})</script>`, user);
