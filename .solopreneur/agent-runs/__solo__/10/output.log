gementToken;slug=new URL(data.shortUrl).pathname.slice(1);result.hidden=false;status.textContent=data.expiresAt?(en?'The share page is ready.':'分享页已生成。'):(en?'The persistent share page is ready.':'长期分享页已生成。');navigator.clipboard.writeText(data.shortUrl).catch(function(){})}catch(error){status.textContent=error.message}finally{ready()}};copy.onclick=function(){navigator.clipboard.writeText(short.href).then(function(){copy.textContent=en?'Copied':'已复制'})};remove.onclick=async function(){if(!slug||!managementToken)return;remove.disabled=true;try{var response=await fetch('/api/shares/'+encodeURIComponent(slug),{method:'DELETE',headers:{authorization:'Bearer '+managementToken}});if(!response.ok)throw Error();result.hidden=true;status.textContent=en?'The share was deleted.':'分享已删除。'}catch(error){status.textContent=en?'Could not delete the share.':'无法删除分享。';remove.disabled=false}}}}})()`;
