function legacyHomePage(user) {
  const share = `<input id="file" type="file" hidden><label id="drop" class="drop" for="file"><div><span class="upload-icon"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5M5 14v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span><strong>拖入文件，立即生成分享页</strong><span>或点击选择文件 · 最大 1 MB</span></div></label><p id="picked" class="picked">支持 Markdown、代码、文本、图片、CSV、HTML 和小型 PDF</p><label class="check"><input id="terms" type="checkbox"><span>我同意 <a href="https://www.cloudflare.com/terms/" target="_blank" rel="noreferrer">Cloudflare 服务条款</a>与<a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">隐私政策</a>，并理解分享链接公开、未认领资源约 60 分钟后自动删除。</span></label><button id="share" class="full" disabled>创建临时分享链接</button><p id="status" class="status" role="status" aria-live="polite"></p><div id="result" class="result" hidden><div class="result-title">${checkIcon}<span>链接已经可以分享</span></div><p><a id="short" class="result-link" target="_blank" rel="noreferrer"></a></p><div class="result-actions"><button id="copy" type="button">复制链接</button><a id="claim" class="button secondary" target="_blank" rel="noreferrer">认领到 Cloudflare</a></div>${user ? '' : '<div class="signup-nudge"><strong>下次更方便一点</strong><p>免费注册后，可以在不同设备查看后续分享记录。当前链接无需注册，已经可以使用。</p><a class="button" href="/register?from=share-success">免费创建账号</a></div>'}</div>`;
  const body = `<main id="main"><div class="page"><section class="hero"><div><p class="eyebrow">无需安装 · 无需登录 · 可控网页分享</p><h1>把文件变成<br>任何人都能打开的网页。</h1><p class="hero-copy">让对方直接在浏览器里阅读，不必下载文件或安装对应软件；你可以决定是否提供下载、添加审阅水印，并控制链接保留时间。</p><div class="proof"><span>${checkIcon}文件加密存储</span><span>${checkIcon}到期自动删除</span><span>${checkIcon}下载与水印由你控制</span></div></div><div class="share-card">${managedShareForm(user)}</div></section><section class="trust-section" aria-labelledby="trust-title"><div class="section-head"><h2 id="trust-title">发网页，而不只是发文件</h2><p>接收者打开就能看，分享者保留对展示方式、下载入口和有效期的控制。</p></div><div class="trust-grid"><article class="trust-card"><h3>减少打开阻力</h3><p>方案、报告和演示稿无需先下载，也不要求对方安装 Word、PowerPoint 或其他应用。</p></article><article class="trust-card"><h3>适合审阅与交付</h3><p>关闭下载入口并添加文字水印，让页面更适合客户审阅、内部评审和阶段性交付。水印用于归属提示，不等同于 DRM。</p></article><article class="trust-card"><h3>生命周期清楚</h3><p>文件按所选有效期安全保存；到期后链接停止访问并自动清理，登录用户也可以创建长期分享。</p></article></div></section><section class="plugin-band"><div><h2>经常在 VS Code 里分享？</h2><p>安装 SoloDrop 插件，直接分享当前文件、拖入文件或从 Explorer 右键完成。</p></div><a class="button" href="https://marketplace.visualstudio.com/items?itemName=SZLK.solodrop">安装 VS Code 插件</a></section></div></main>`;
  return shell('快速把文件分享成网页', body, `<script src="/pow.js"></script><script>window.SoloDrop.initShare(${MAX_FILE_BYTES});document.getElementById('copy').addEventListener('click',function(){navigator.clipboard.writeText(document.getElementById('short').href).then(()=>{this.textContent='已复制'})})</script>`, user);
}

function homePage(user, locale = 'zh') {
  const en=locale==='en';
  let html=legacyHomePage(user);
  html=html.replace('</head>','<style>.faq-list{max-width:none;width:100%;margin-left:0;margin-right:0}</style></head>');
  const replacements=en?[
    ['lang="zh-CN"','lang="en"'],['跳到主要内容','Skip to main content'],['主导航','Main navigation'],['VS Code 插件','VS Code extension'],['登录','Log in'],['免费注册','Sign up free'],['服务条款','Terms'],['隐私政策','Privacy'],['产品补充说明','Legal supplement'],
    ['快速把文件分享成网页 · SoloDrop','Free Temporary File Sharing — No Sign-Up | SoloDrop'],['无需登录，把文件快速变成可分享的临时网页。','Turn a file into a temporary shareable web page without signing in.'],
    ['无需安装 · 无需登录 · 免费临时分享','No install · No sign-up · Free temporary sharing'],['把文件变成<br>任何人都能打开的网页。','Turn a file into<br>a web page anyone can open.'],['拖入一个文件，SoloDrop 会生成经过在线检查的临时网页和简洁短链。先把东西分享出去，账号以后再说。','Drop in one file. SoloDrop creates a temporary browser-ready page, checks that it is online, and gives you a clean link. Share first; create an account later.'],
    ['无需安装 · 无需登录 · 可控网页分享','No install · No sign-up · Controlled web sharing'],['让对方直接在浏览器里阅读，不必下载文件或安装对应软件；你可以决定是否提供下载、添加审阅水印，并控制链接保留时间。','Let recipients read in the browser without downloading a file or installing an app. You control downloads, review watermarks, and link lifetime.'],['文件加密存储','Encrypted file storage'],['到期自动删除','Automatic expiry cleanup'],['下载与水印由你控制','You control downloads and watermarks'],
    ['SoloDrop 不保存文件内容','SoloDrop does not store file contents'],['由 Cloudflare 临时 Worker 承载','Hosted by a temporary Cloudflare Worker'],['公开前完成可用性检查','Checked online before delivery'],['拖入文件，立即生成分享页','Drop a file to create its share page'],['或点击选择文件 · 最大 1 MB','or choose a file · 1 MB maximum'],['支持 Markdown、代码、文本、图片、CSV、HTML 和小型 PDF','Markdown, code, text, images, CSV, HTML, and small PDFs'],
    ['我同意 <a href="https://www.cloudflare.com/terms/" target="_blank" rel="noreferrer">Cloudflare Terms</a>与<a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">Privacy</a>，并理解分享链接公开、未认领资源约 60 分钟后自动删除。','I agree to the <a href="https://www.cloudflare.com/terms/" target="_blank" rel="noreferrer">Cloudflare Terms</a> and <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">Privacy Policy</a>. I understand the link is public and an unclaimed resource is deleted after about 60 minutes.'],
    ['创建临时分享链接','Create temporary share link'],['链接已经可以分享','Your link is ready to share'],['复制链接','Copy link'],['认领到 Cloudflare','Claim on Cloudflare'],['下次更方便一点','Make the next share easier'],['免费注册后，可以在不同设备查看后续分享记录。当前链接无需注册，已经可以使用。','Create a free account to see future share activity across devices. This link already works without an account.'],['免费创建账号','Create free account'],
    ['或点击选择文件 · 最大 10 MB','or choose a file · 10 MB maximum'],['支持 Markdown、代码、文本、图片、CSV、HTML、PDF、Word 和 PowerPoint','Markdown, code, text, images, CSV, HTML, PDF, Word, and PowerPoint'],['允许下载原文件','Allow original-file download'],['关闭后，页面只保留在线预览','When off, the page keeps online preview only'],['文字水印（可选）','Text watermark (optional)'],['例如：仅供客户审阅','For example: Client review only'],['链接有效期','Link lifetime'],['1 天','1 day'],['7 天','7 days'],['30 天','30 days'],['长期保留','Keep until deleted'],['我确认文件将通过公开链接访问，并同意 SoloDrop 在所选有效期内保存文件内容，直到到期或我主动删除。','I understand the file will be available through a public link and agree that SoloDrop may store it until it expires or I delete it.'],['创建分享链接','Create share link'],['删除分享','Delete share'],['需要长期保留？','Need a persistent link?'],['免费注册后可创建长期链接，并在不同设备查看分享记录。','Create a free account for persistent links and cross-device share history.'],
    ['发网页，而不只是发文件','Share a web page, not just a file'],['接收者打开就能看，分享者保留对展示方式、下载入口和有效期的控制。','Recipients can read immediately while you retain control over presentation, downloads, and lifetime.'],['减少打开阻力','Remove opening friction'],['方案、报告和演示稿无需先下载，也不要求对方安装 Word、PowerPoint 或其他应用。','Plans, reports, and decks open without a download or Word, PowerPoint, and other apps.'],['适合审阅与交付','Made for review and delivery'],['关闭下载入口并添加文字水印，让页面更适合客户审阅、内部评审和阶段性交付。水印用于归属提示，不等同于 DRM。','Disable the download action and add a text watermark for client review, internal feedback, and staged delivery. A watermark signals ownership; it is not DRM.'],['生命周期清楚','Clear lifecycle'],['文件按所选有效期安全保存；到期后链接停止访问并自动清理，登录用户也可以创建长期分享。','Files are kept securely for the selected lifetime. Expired links stop working and are cleaned up automatically; signed-in users can also create persistent shares.'],
    ['临时分享，也应该清楚可靠','Temporary sharing should still be transparent'],['我们把数据去向、链接性质和到期规则直接说清楚，让你在点击分享前知道会发生什么。','Know where the file goes, who can open the link, and when the temporary resource expires before you share.'],['不做文件保管','No file custody'],['文件仅用于当前临时部署，不写入 SoloDrop 的 Durable Object、R2 或文件库。','The file is used only for this deployment. SoloDrop does not write its contents to Durable Objects, R2, or a file library.'],['临时就是临时','Temporary means temporary'],['未认领的 Cloudflare 临时账户及资源约 60 分钟后自动删除，不包装成永久存储。','An unclaimed Cloudflare temporary account and its resources are deleted after about 60 minutes.'],['先验证，再交付','Verified before delivery'],['分享页上线后会先经过可访问性检查，再生成短链并交给你。','SoloDrop checks the published page before creating the short link you receive.'],['经常在 VS Code 里分享？','Share from VS Code often?'],['安装 SoloDrop 插件，直接分享当前文件、拖入文件或从 Explorer 右键完成。','Install SoloDrop to share the active file, drop a file, or use the Explorer context menu.'],['安装 VS Code 插件','Install the VS Code extension'],['已复制','Copied']
  ]:[];
  for(const [from,to] of replacements) html=html.split(from).join(to);
  if(en) for(const [from,to] of [['无需安装 · 无需Log in · 免费临时分享','No install · No sign-up · Free temporary sharing'],['无需安装 · 无需Log in · 可控网页分享','No install · No sign-up · Controlled web sharing'],['需要Keep until deleted？','Need a persistent link?'],['Sign up free后可创建长期链接，并在不同设备查看分享记录。','Create a free account for persistent links and cross-device share history.'],['文件按所选有效期安全保存；到期后链接停止访问并自动清理，Log in用户也可以创建长期分享。','Files are kept securely for the selected lifetime. Expired links stop working and are cleaned up automatically; signed-in users can also create persistent shares.'],['Sign up free后，可以在不同设备查看后续分享记录。当前链接无需注册，已经可以使用。','Create a free account to see future share activity across devices. This link already works without an account.'],['安装 VS Code extension','Install the VS Code extension']]) html=html.split(from).join(to);
  if(en) html=html.replaceAll('href="/"','href="/en"').replaceAll('href="/login"','href="/en/login"').replaceAll('href="/register','href="/en/register').replaceAll('href="/terms"','href="/en/terms"').replaceAll('href="/privacy"','href="/en/privacy"').replaceAll('href="/legal-supplement"','href="/en/legal-supplement"').replace('href="/api/auth/logout"','href="/api/auth/logout?locale=en"');
  const faqs=en?[
    ['Do I need an account to share a file with SoloDrop?','No. Guest shares can last 1, 7, or 30 days. Sign in only when you want a persistent link and cross-device history.'],
    ['Does SoloDrop store my file?','Yes. The file is stored in Cloudflare R2 only to serve its share page, then deleted after its selected lifetime or when its owner deletes it.'],
    ['Can I stop recipients from downloading the file?','You can remove the download action. Browser preview still requires sending content to the recipient, so this is a sharing preference rather than DRM.'],
    ['Which files can become browser previews?','Markdown, code, text, images, CSV, HTML, PDF, DOCX, and PPTX files up to 10 MB.'],
    ['Is a SoloDrop share link private?','No. Anyone with the link may open the page, so do not share secrets or private content.']
  ]:[
    ['使用 SoloDrop 分享文件需要登录吗？','不需要。游客可以选择保留 1 天、7 天或 30 天；只有长期链接和跨设备记录需要登录。'],
    ['SoloDrop 会保存我的文件吗？','会。文件仅为提供分享页而存入 Cloudflare R2，并在所选有效期结束或所有者主动删除后清理。'],
    ['可以阻止接收者下载文件吗？','可以隐藏下载入口；但在线预览仍需把内容传给浏览器，因此这是分享偏好和操作约束，不是 DRM。'],
    ['哪些文件可以直接生成网页预览？','支持最大 10 MB 的 Markdown、代码、文本、图片、CSV、HTML、PDF、DOCX 和 PPTX。'],
    ['分享链接是私密的吗？','不是。拿到链接的人都可能访问分享页，请不要上传密钥、密码或其他私密内容。']
  ];
  const answer=en?'SoloDrop turns files into controlled browser-ready share pages. Recipients read without installing the source application, while senders choose downloads, a review watermark, and link lifetime.':'SoloDrop 把文件变成可控的浏览器分享页。接收者无需安装原始应用即可阅读，分享者可以选择是否允许下载、添加审阅水印并设置链接有效期。';
  const modules='<section class="answer-section" aria-labelledby="answer-title"><div class="section-head"><h2 id="answer-title">'+(en?'What is SoloDrop?':'SoloDrop 是什么？')+'</h2><p>'+answer+'</p></div><div class="answer-grid"><article class="answer-card"><h3>'+(en?'I need to share one file now':'只想马上分享一个文件')+'</h3><p>'+(en?'Use this web page. Get a checked temporary link without installing software or creating an account.':'直接使用当前网页，无需安装软件或创建账号，即可获得经过检查的临时链接。')+'</p></article><article class="answer-card"><h3>'+(en?'I often share from VS Code':'经常从 VS Code 分享')+'</h3><p>'+(en?'Install the extension to share the active editor, drop a file, or use the Explorer context menu.':'安装插件后，可以分享当前编辑器文件、拖入文件，或从 Explorer 右键创建预览。')+'</p></article></div></section><section class="faq" aria-labelledby="faq-title"><div class="section-head"><h2 id="faq-title">'+(en?'Temporary file sharing FAQ':'临时文件分享常见问题')+'</h2><p>'+(en?'Straight answers about accounts, storage, expiry, and public access.':'关于登录、文件保存、链接时效和公开范围，答案都在这里。')+'</p></div><div class="faq-list">'+faqs.map(([q,a])=>'<details><summary>'+q+'</summary><p>'+a+'</p></details>').join('')+'</div></section>';
  html=html.replace('<section class="plugin-band">',modules+'<section class="plugin-band">');
  const page=en?SITE_URL+'/en':SITE_URL+'/', title=en?'Controlled File Sharing as a Web Page | SoloDrop':'可控文件分享｜生成带水印的网页预览 · SoloDrop', description=en?'Turn files into browser-ready share pages with optional downloads, text watermarks, and controlled lifetime.':'把文件变成浏览器可读的分享页，可选择隐藏下载、添加文字水印并控制链接有效期。';
  const graph={'@context':'https://schema.org','@graph':[{'@type':'WebSite',url:page,name:'SoloDrop',inLanguage:en?'en':'zh-CN'},{'@type':'SoftwareApplication',name:'SoloDrop',url:page,applicationCategory:'UtilitiesApplication',operatingSystem:'Web, Windows, macOS, Linux',description:answer,offers:{'@type':'Offer',price:'0',priceCurrency:'USD'}},{'@type':'FAQPage',mainEntity:faqs.map(([name,text])=>({'@type':'Question',name,acceptedAnswer:{'@type':'Answer',text}}))}]};
  const meta='<link rel="canonical" href="'+page+'"><link rel="alternate" hreflang="zh-CN" href="'+SITE_URL+'/"><link rel="alternate" hreflang="en" href="'+SITE_URL+'/en"><link rel="alternate" hreflang="x-default" href="'+SITE_URL+'/"><meta property="og:type" content="website"><meta property="og:title" content="'+title+'"><meta property="og:description" content="'+description+'"><meta property="og:url" content="'+page+'"><meta property="og:image" content="'+SITE_URL+'/social-card.svg"><meta name="twitter:card" content="summary_large_image"><script type="application/ld+json">'+JSON.stringify(graph).replace(/</g,'\\u003c')+'</script>';
  html=html.replace('<meta name="robots" content="noindex,follow">','<meta name="robots" content="index,follow,max-image-preview:large">'+meta).replace(/<title>[^<]+<\/title>/,'<title>'+title+'</title>').replace(/<meta name="description" content="[^"]+">/,'<meta name="description" content="'+description+'">');
  if(en) html=html.replace('<a class="navlink" href="/en" lang="en" hreflang="en">EN</a>','<a class="navlink" href="/" lang="zh-CN" hreflang="zh-CN">中</a>');
  return html;
}

function legacyAuthPage(mode, message = '') {
  const register = mode === 'register';
  return shell(register ? '注册' : '登录', `<main id="main" class="auth card"><a class="brand" href="/"><img src="/favicon.svg" alt=""><span>SoloDrop</span></a><h1>${register ? '保存你的分享记录' : '欢迎回来'}</h1><p class="muted">${register ? '分享始终可以先完成。注册后，你可以跨设备查看后续分享活动。' : '登录后查看自己的分享活动。'}</p>${message ? `<p class="result">${esc(message)}</p>` : ''}<form method="post" action="/api/auth/${mode}">${register ? '<label class="field">昵称<input name="name" autocomplete="name" maxlength="80"></label>' : ''}<label class="field">邮箱<input type="email" name="email" autocomplete="email" required></label><label class="field">密码<input type="password" name="password" autocomplete="${register ? 'new-password' : 'current-password'}" minlength="8" required></label><button class="full">${register ? '免费创建账号' : '登录'}</button></form><p class="muted">${register ? '已有账号？<a href="/login">直接登录</a>' : '还没有账号？<a href="/register">免费注册</a> · <a href="/forgot">忘记密码</a>'}</p><p><a href="/">← 先不登录，继续分享</a></p></main>`);
}

function localizeSecondaryPage(html, locale) {
  if(locale!=='en') return html;
  const pairs=[['lang="zh-CN"','lang="en"'],['跳到主要内容','Skip to main content'],['主导航','Main navigation'],['VS Code 插件','VS Code extension'],['我的记录','My activity'],['退出','Log out'],['登录','Log in'],['免费注册','Sign up free'],['服务条款','Terms'],['隐私政策','Privacy'],['产品补充说明','Legal supplement'],['保存你的分享记录','Keep your share activity'],['欢迎回来','Welcome back'],['分享始终可以先完成。注册后，你可以跨设备查看后续分享活动。','Sharing always comes first. Sign up to see future activity across devices.'],['登录后查看自己的分享活动。','Log in to see your share activity.'],['昵称','Name'],['邮箱','Email'],['密码','Password'],['免费创建账号','Create free account'],['已有账号？','Already have an account?'],['直接登录','Log in'],['还没有账号？','New to SoloDrop?'],['忘记密码','Forgot password?'],['← 先不登录，继续分享','← Keep sharing without an account'],['还没有分享记录。回到首页分享第一个文件吧。','No share activity yet. Return home to share your first file.'],['这里只保留分享时间、文件名、大小和结果状态，不保存文件内容。','Only the share time, file name, size, and result are kept here. File contents are not stored.'],['这里显示你的分享记录；文件内容按所选有效期存放在 Cloudflare R2。','This page shows your share history; file contents remain in Cloudflare R2 for the lifetime you selected.'],['最近活动','Recent activity'],['打开','Open'],['法律文件暂时无法加载，请稍后重试。','The legal document is temporarily unavailable. Please try again later.']];
  for(const [from,to] of pairs) html=html.split(from).join(to);
  for(const [from,to] of [['无需Log in，把文件快速变成可分享的临时网页。','Turn a file into a temporary shareable web page without signing in.'],['注册 · SoloDrop','Sign up · SoloDrop'],['直接Log in','Log in'],['← 先不Log in，继续分享','← Keep sharing without an account']]) html=html.split(from).join(to);
  return html.replaceAll('href="/"','href="/en"').replaceAll('href="/login"','href="/en/login"').replaceAll('href="/register"','href="/en/register"').replaceAll('href="/forgot"','href="/en/forgot"').replaceAll('href="/terms"','href="/en/terms"').replaceAll('href="/privacy"','href="/en/privacy"').replaceAll('href="/legal-supplement"','href="/en/legal-supplement"').replace(/(<form[^>]+>)/,'$1<input type="hidden" name="locale" value="en">');
}

function authPage(mode, message = '', locale = 'zh') {
  return localizeSecondaryPage(legacyAuthPage(mode,message),locale);
}

function accountPage(user, activities) { const rows=activities.length?activities.map((x)=>`<div class="item"><div><strong>${esc(x.file_name)}</strong><div class="muted">${Math.ceil(x.size_bytes/1024)} KB · ${new Date(x.created_at).toLocaleString('zh-CN')} · ${esc(x.status)}</div></div>${x.short_slug?`<a href="/${esc(x.short_slug)}" target="_blank">打开</a>`:''}</div>`).join(''):'<p class="muted">还没有分享记录。回到首页分享第一个文件吧。</p>'; return shell('我的记录',`<main id="main" class="page" style="padding:56px 0 90px"><h1>${esc(user.name||user.email)}</h1><p class="muted">这里显示你的分享记录；文件内容按所选有效期存放在 Cloudflare R2。</p><section class="history"><h2>最近活动</h2>${rows}</section></main>`,'',user); }
function legalPage(title,document){const groups=document?.composition||document?.supplement?.composition||[];const sections=groups.flatMap((g)=>g.sections||[]).map((s)=>`<section><h2>${esc(s.title)}</h2><p>${esc(s.body_markdown||s.body||'').replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br>')}</p></section>`).join('');return shell(title,`<main id="main" class="page card" style="margin-top:48px;margin-bottom:72px;padding:clamp(24px,5vw,56px);max-width:860px"><h1>${esc(document?.title||title)}</h1>${sections||'<p class="muted">法律文件暂时无法加载，请稍后重试。</p>'}</main>`);}

