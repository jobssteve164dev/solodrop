+  const sources = { ...context.globalState.get<Record<string, string>>(HISTORY_SOURCES_KEY, {}) };
+  const sanitized = records.map(({ sourcePath, ...record }) => {
+    if (sourcePath) sources[record.id] = sourcePath;
+    return record;
