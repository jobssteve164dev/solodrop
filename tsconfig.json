{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "rootDir": "src",
    "outDir": "out",
    "lib": ["es2022", "dom"],
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out"]
}
